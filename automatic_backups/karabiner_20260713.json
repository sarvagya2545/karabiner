              {
                "to": [
                  {
                    "shell_command": "export PATH=\"/opt/homebrew/bin:$PATH\""
                  },
                  {
                    "shell_command": "cd ~/dotfiles/karabiner/.config/karabiner"
                  },
                  {
                    "shell_command": "ERROR_OUTPUT=$({ npm run build && launchctl kickstart -k gui/$(id -u)/org.pqrs.karabiner.karabiner_console_user_server; } 2>&1)"
                  },
                  {
                    "shell_command": "if [ $? -eq 0 ]; then"
                  },
                  {
                    "shell_command": "osascript -e 'display notification \"Rules rebuilt and reloaded\" with title \"Karabiner\"'"
                  },
                  {
                    "shell_command": "else"
                  },
                  {
                    "shell_command": "SAFE_ERROR=$(echo \"$ERROR_OUTPUT\" | tail -c 200 | tr '"
                  },
                  {
                    "shell_command": "' ' ' | sed 's/\"/\\\"/g')"
                  },
                  {
                    "shell_command": "osascript -e \"display notification \"$SAFE_ERROR\" with title \"Karabiner Build Failed\" sound name \"Basso\"\""
                  },
                  {
                    "shell_command": "fi"
                  }
